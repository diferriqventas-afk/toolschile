# ToolsChile — Variables de Entorno
# Copia este archivo como .env.local y completa los valores

# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/toolschile"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-uno-con: openssl rand -base64 32"

# ─── GOOGLE OAUTH (opcional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID="tu_google_client_id"
GOOGLE_CLIENT_SECRET="tu_google_client_secret"

# ─── TRANSBANK WEBPAY ─────────────────────────────────────────────────────────
# Para testing usa las credenciales de integración de Transbank:
# https://www.transbankdevelopers.cl/documentacion/como_empezar
TRANSBANK_COMMERCE_CODE="597055555532"
TRANSBANK_API_KEY_SECRET="579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C"
TRANSBANK_ENV="integration"  # o "production"

# ─── MERCADO PAGO ─────────────────────────────────────────────────────────────
# Obtén tus credenciales en: https://www.mercadopago.cl/developers
MP_ACCESS_TOKEN="TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
MP_PUBLIC_KEY="TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ─── CLOUDINARY (para imágenes de productos) ──────────────────────────────────
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="tu_cloud_name"

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="ToolsChile"
NEXT_PUBLIC_WHATSAPP="+56912345678"
